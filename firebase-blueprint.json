      "schema": "User",
      "description": "Main user account configuration partitioned by user system credentials"
    },
    "/roles/{roleId}": {
      "schema": "Role",
      "description": "Authority settings mapped for RBAC validations"
    },
    "/permissions/{permissionId}": {
      "schema": "Permission",
      "description": "System capability key configurations database list"
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Governance immutability logs tracking key administrative database events"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
