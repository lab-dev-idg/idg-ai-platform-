rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Core Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    // User Schematized Validator
    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string 
        && data.email.size() > 0 
        && data.email.size() <= 256 
        && (!data.keys().hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 256))
        && (!data.keys().hasAny(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 2048));
    }
    
    // Shipment Schematized Validator
    function isValidShipment(data) {
      return data.trackingNumber is string 
        && data.trackingNumber.size() > 0 
        && data.trackingNumber.size() <= 128 
        && data.status is string 
        && data.status.size() > 0 
        && data.status.size() <= 128 
        && data.userId == request.auth.uid
        && (!data.keys().hasAny(['estimatedDelivery']) || (data.estimatedDelivery is string && data.estimatedDelivery.size() <= 128));
    }

    // Rules for /users/{userId}
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      
      // Strict prohibition of general listing profiles
      allow list: if false;
      
      allow create: if isOwner(userId) 
        && isValidId(userId) 
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasAll(['uid', 'email', 'createdAt'])
        && request.resource.data.keys().size() <= 5
        && isValidUser(request.resource.data);
        
      allow update: if isOwner(userId)
        && isValidId(userId)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.keys().size() <= 5
        && isValidUser(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL']);
        
      allow delete: if false;
      
      // Sub-collection: shipments
      match /shipments/{shipmentId} {
        allow get: if isOwner(userId) && isValidId(userId) && isValidId(shipmentId);
        
        // Secure Query List Enforcement
        allow list: if isOwner(userId) && isValidId(userId);
        
        allow create: if isOwner(userId)
          && isValidId(userId)
          && isValidId(shipmentId)
          && request.resource.data.updatedAt == request.time
          && request.resource.data.keys().hasAll(['trackingNumber', 'status', 'userId', 'updatedAt'])
          && request.resource.data.keys().size() <= 5
          && isValidShipment(request.resource.data);
          
        allow update: if isOwner(userId)
          && isValidId(userId)
          && isValidId(shipmentId)
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.trackingNumber == resource.data.trackingNumber
          && request.resource.data.updatedAt == request.time
          && request.resource.data.keys().size() <= 5
          && isValidShipment(request.resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'estimatedDelivery', 'updatedAt']);
          
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(shipmentId);
      }
    }
  }
}
