{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@modules/*": ["./apps/ai-platform/src/modules/*"],
      "@idg/ui": ["./src/components/idg-ui/index.tsx"],
      "@idg/realtime": ["./src/services/firebase/listeners/sharedListener.ts"],
      "@idg/domain": ["./src/shared/domain/customs/types.ts"],
      "@/shared/ui/*": ["./src/components/ui/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "components", "lib", "vite-env.d.ts", "*.ts", "*.tsx", "apps"]
}
